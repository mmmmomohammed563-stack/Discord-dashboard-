<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body { background:#0f172a; color:white; }
    .card { background:#1e293b; border:none; color:white; }
  </style>
</head>

<body class="p-4">

<div class="container text-center">

  <h2>Welcome <%= user.username %></h2>

  <% if (user.avatar) { %>
    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png"
    width="100" style="border-radius:50%">
  <% } %>

  <a href="/logout" class="btn btn-danger mt-2">Logout</a>

  <h3 class="mt-4">Your Servers</h3>

  <div id="guilds" class="row g-3 mt-2"></div>

</div>

<script>
async function loadGuilds() {
  const res = await fetch("/guilds");
  const guilds = await res.json();

  const container = document.getElementById("guilds");

  guilds.forEach(g => {

    const icon = g.icon
      ? `https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png`
      : "https://cdn.discordapp.com/embed/avatars/0.png";

    container.innerHTML += `
      <div class="col-md-4">
        <div class="card p-3">

          <img src="${icon}" width="50" style="border-radius:50%">

          <h5>${g.name}</h5>

          <a class="btn btn-primary btn-sm mt-2"
             href="/dashboard/${g.id}">
             Manage
          </a>

        </div>
      </div>
    `;
  });
}

loadGuilds();
</script>

</body>
</html>
